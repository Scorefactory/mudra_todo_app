<Window x:Class="TodoWpfPortable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TodoWpfPortable"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="할일이 머드라"
        Icon="pack://application:,,,/Assets/lizard.ico"
        Width="430"
        Height="680"
        MinWidth="360"
        MinHeight="520"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#101114" />
        <SolidColorBrush x:Key="PanelBrush" Color="#181A1F" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#20232B" />
        <SolidColorBrush x:Key="InputBrush" Color="#20232B" />
        <SolidColorBrush x:Key="LineBrush" Color="#262A33" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TodoTextBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="SubTodoTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="CompletedTextBrush" Color="#7E8795" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4F9DFF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF6B73" />
        <SolidColorBrush x:Key="CheckBrush" Color="#22C55E" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:SubItemMarginConverter x:Key="SubItemMarginConverter" />

        <Style x:Key="ShellButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DevToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <StackPanel Orientation="Horizontal"
                                    Background="Transparent"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                            <Ellipse x:Name="StateDot"
                                     Width="7"
                                     Height="7"
                                     Margin="0,0,6,0"
                                     Fill="#6B7280"
                                     VerticalAlignment="Center" />
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter TargetName="StateDot" Property="Fill" Value="{DynamicResource CheckBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI Symbol, Malgun Gothic" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="16"
                              Height="16"
                              Background="Transparent">
                            <Border x:Name="Box"
                                    Background="Transparent"
                                    BorderBrush="#475569"
                                    BorderThickness="1.4"
                                    CornerRadius="4" />
                            <Path x:Name="CheckMark"
                                  Data="M 3 8 L 6.5 11.5 L 13 4.5"
                                  Stroke="{DynamicResource CheckBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource CheckBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource CheckBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="42"
                              Height="24"
                              Background="Transparent">
                            <Border x:Name="Track"
                                    Background="{DynamicResource PanelSoftBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12" />
                            <Ellipse x:Name="Thumb"
                                     Width="18"
                                     Height="18"
                                     Margin="3"
                                     Fill="{DynamicResource TextMutedBrush}"
                                     HorizontalAlignment="Left" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="3" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="{DynamicResource TextMutedBrush}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="2"
                                                        Opacity="0.5" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="3" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="0" />
                                <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Column="0"
                                                    Grid.Row="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    Margin="{TemplateBinding Padding}" />

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Grid.Row="0"
                                       Width="3"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
        
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" TextElement.FontFamily="Segoe UI Emoji, Segoe UI Symbol, Malgun Gothic">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
            <ToggleButton x:Name="TopmostToggle"
                          IsChecked="True"
                          Checked="TopmostToggle_Changed"
                          Unchecked="TopmostToggle_Changed"
                                  Style="{StaticResource DevToggleStyle}"
                                  Content="항상 위" />

                    <ToggleButton x:Name="RightDockToggle"
                                  Margin="8,0,0,0"
                                  IsChecked="True"
                                  Checked="RightDockToggle_Changed"
                                  Unchecked="RightDockToggle_Changed"
                                  Style="{StaticResource DevToggleStyle}"
                                  Content="우측 고정" />
                </StackPanel>

                <ToggleButton x:Name="SettingsToggle"
                              DockPanel.Dock="Right"
                              Content="▾"
                              Checked="SettingsToggle_Changed"
                              Unchecked="SettingsToggle_Changed"
                              Style="{StaticResource IconToggleStyle}" />
            </DockPanel>

            <Border x:Name="SettingsPanel"
                    Margin="0,10,0,0"
                    Padding="12"
                    MinWidth="310"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="스타일"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="ThemeCombo"
                              Grid.Row="0"
                              Grid.Column="1"
                              Height="28"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="기본" IsSelected="True" />
                        <ComboBoxItem Content="Dark 2026" />
                    </ComboBox>

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="할일 목록"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,12,0,2" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="메인 폰트"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <DockPanel Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,8,0,0">
                        <TextBlock x:Name="FontSizeValueText"
                                   DockPanel.Dock="Right"
                                   Width="28"
                                   Text="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="FontSizeSlider"
                                Minimum="12"
                                Maximum="18"
                                Value="13"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="FontSizeSlider_ValueChanged" />
                    </DockPanel>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="서브 폰트"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <DockPanel Grid.Row="3"
                               Grid.Column="1"
                               Margin="0,8,0,0">
                        <TextBlock x:Name="SubFontSizeValueText"
                                   DockPanel.Dock="Right"
                                   Width="28"
                                   Text="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="SubFontSizeSlider"
                                Minimum="11"
                                Maximum="17"
                                Value="13"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="SubFontSizeSlider_ValueChanged" />
                    </DockPanel>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="메인 간격"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <DockPanel Grid.Row="4"
                               Grid.Column="1"
                               Margin="0,8,0,0">
                        <TextBlock x:Name="MainSpacingValueText"
                                   DockPanel.Dock="Right"
                                   Width="28"
                                   Text="3"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="MainSpacingSlider"
                                Minimum="0"
                                Maximum="14"
                                Value="3"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MainSpacingSlider_ValueChanged" />
                    </DockPanel>

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Text="서브 간격"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <DockPanel Grid.Row="5"
                               Grid.Column="1"
                               Margin="0,8,0,0">
                        <TextBlock x:Name="SubSpacingValueText"
                                   DockPanel.Dock="Right"
                                   Width="28"
                                   Text="26"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="ListSpacingSlider"
                                Minimum="20"
                                Maximum="36"
                                Value="26"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="ListSpacingSlider_ValueChanged" />
                    </DockPanel>

                    <TextBlock Grid.Row="6"
                               Grid.ColumnSpan="2"
                               Text="메모"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,14,0,2" />

                    <TextBlock Grid.Row="7"
                               Grid.Column="0"
                               Text="메모 폰트"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <DockPanel Grid.Row="7"
                               Grid.Column="1"
                               Margin="0,8,0,0">
                        <TextBlock x:Name="MemoFontSizeValueText"
                                   DockPanel.Dock="Right"
                                   Width="28"
                                   Text="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="MemoFontSizeSlider"
                                Minimum="11"
                                Maximum="18"
                                Value="13"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MemoFontSizeSlider_ValueChanged" />
                    </DockPanel>

                    <TextBlock Grid.Row="8"
                               Grid.Column="0"
                               Text="새 메모 스티키"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <CheckBox x:Name="AutoStickyNewMemoToggle"
                              Grid.Row="8"
                              Grid.Column="1"
                              IsChecked="True"
                              Checked="AutoStickyNewMemoToggle_Changed"
                              Unchecked="AutoStickyNewMemoToggle_Changed"
                              Margin="0,8,0,0"
                              Style="{StaticResource SwitchCheckBoxStyle}"
                              VerticalAlignment="Center" />

                    <TextBlock Grid.Row="9"
                               Grid.ColumnSpan="2"
                               Text="스티키노트"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,14,0,2" />

                    <TextBlock Grid.Row="10"
                               Grid.Column="0"
                               Text="스티키 폰트"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <DockPanel Grid.Row="10"
                               Grid.Column="1"
                               Margin="0,8,0,0">
                        <TextBlock x:Name="StickyNoteFontSizeValueText"
                                   DockPanel.Dock="Right"
                                   Width="28"
                                   Text="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="StickyNoteFontSizeSlider"
                                Minimum="11"
                                Maximum="22"
                                Value="13"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="StickyNoteFontSizeSlider_ValueChanged" />
                    </DockPanel>

                    <TextBlock Grid.Row="11"
                               Grid.Column="0"
                               Text="스티키 항상 위"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <CheckBox x:Name="StickyNoteTopmostToggle"
                              Grid.Row="11"
                              Grid.Column="1"
                              IsChecked="True"
                              Checked="StickyNoteTopmostToggle_Changed"
                              Unchecked="StickyNoteTopmostToggle_Changed"
                              Margin="0,8,0,0"
                              Style="{StaticResource SwitchCheckBoxStyle}"
                              VerticalAlignment="Center" />

                    <TextBlock Grid.Row="12"
                               Grid.Column="0"
                               Text="스티키 정렬"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="StickyArrangeDirectionCombo"
                              Grid.Row="12"
                              Grid.Column="1"
                              Height="28"
                              Margin="0,8,0,0"
                              SelectionChanged="StickyArrangeDirectionCombo_SelectionChanged">
                        <ComboBoxItem Content="가로" Tag="Horizontal" />
                        <ComboBoxItem Content="세로" Tag="Vertical" IsSelected="True" />
                    </ComboBox>

                    <Button Grid.Row="13"
                            Grid.Column="1"
                            Content="설정 리셋"
                            Click="SettingsReset_Click"
                            Foreground="{DynamicResource TextMutedBrush}"
                            HorizontalAlignment="Right"
                            Padding="0"
                            Margin="0,10,0,0"
                            Style="{StaticResource ShellButtonStyle}" />

                    <StackPanel Grid.Row="14"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0">
                        <Viewbox Width="193"
                                 Height="84"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center">
                            <Canvas x:Name="SettingsSpriteCanvas"
                                    Width="385"
                                    Height="168" />
                        </Viewbox>
                        <TextBlock x:Name="SettingsVersionText"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="제작자 남지웅@야생동물검역센터"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel>
                <TextBox x:Name="NewTodoBox"
                         BorderThickness="0"
                         Background="Transparent"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         PreviewKeyDown="NewTodoBox_KeyDown"
                         ToolTip="Enter로 추가, Shift+Enter로 줄바꿈"
                         VerticalContentAlignment="Center" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button Content="+ 메모"
                            Click="AddMemo_Click"
                            Foreground="{DynamicResource AccentBrush}"
                            FontWeight="SemiBold"
                            Padding="0"
                            Margin="0,0,12,0"
                            Style="{StaticResource ShellButtonStyle}" />
                    <Button Content="+ 할일"
                            Click="AddTodo_Click"
                            Foreground="{DynamicResource AccentBrush}"
                            FontWeight="SemiBold"
                            Padding="0"
                            Style="{StaticResource ShellButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="2,0,0,12">
            <Button x:Name="OpenFilterButton"
                    Click="OpenFilter_Click"
                    Padding="0"
                    Foreground="{DynamicResource TextBrush}"
                    Style="{StaticResource ShellButtonStyle}" />
            <TextBlock Text=" / "
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13"
                       VerticalAlignment="Center" />
            <Button x:Name="CompletedFilterButton"
                    Click="CompletedFilter_Click"
                    Padding="0"
                    Foreground="{DynamicResource TextMutedBrush}"
                    Style="{StaticResource ShellButtonStyle}" />
            <TextBlock Text=" / "
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13"
                       VerticalAlignment="Center" />
            <Button x:Name="RepeatFilterButton"
                    Click="RepeatFilter_Click"
                    Padding="0"
                    Foreground="{DynamicResource TextMutedBrush}"
                    Style="{StaticResource ShellButtonStyle}" />
            <TextBlock Text=" / "
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13"
                       VerticalAlignment="Center" />
            <Button x:Name="MemoFilterButton"
                    Click="MemoFilter_Click"
                    Padding="0"
                    Foreground="{DynamicResource TextMutedBrush}"
                    Style="{StaticResource ShellButtonStyle}" />        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="MemoTrashPanel"
                        Grid.Row="0"
                        Orientation="Vertical"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Visibility="Collapsed">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <TextBlock Text="검색"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox x:Name="MemoSearchBox"
                             Width="160"
                             Height="28"
                             Margin="0,0,14,0"
                             Padding="10,4"
                             BorderThickness="0"
                             Background="{DynamicResource InputBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             TextChanged="MemoSearchBox_TextChanged"
                             ToolTip="메모 검색" />
                    <Button x:Name="MemoSearchClearButton"
                            Click="MemoSearchClear_Click"
                            Foreground="{DynamicResource TextMutedBrush}"
                            Padding="0"
                            Width="14"
                            Height="14"
                            Margin="2,0,14,0"
                            Visibility="Collapsed"
                            Style="{StaticResource ShellButtonStyle}">
                        <Path Data="M 7 7 L 17 17 M 17 7 L 7 17"
                              Stroke="{DynamicResource TextMutedBrush}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="8"
                              Height="8"
                              Stretch="Uniform" />
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0">
                    <Button x:Name="MemoTrashToggleButton"
                            Content="휴지통"
                            Click="MemoTrashToggle_Click"
                            Foreground="{DynamicResource TextMutedBrush}"
                            Padding="0"
                            Margin="0,0,12,0"
                            Style="{StaticResource ShellButtonStyle}" />
                    <Button x:Name="EmptyMemoTrashButton"
                            Content="휴지통 비우기"
                            Click="EmptyMemoTrash_Click"
                            Foreground="{DynamicResource DangerBrush}"
                            Padding="0"
                            Visibility="Collapsed"
                            Style="{StaticResource ShellButtonStyle}" />
                </StackPanel>
            </StackPanel>
            <ListBox x:Name="TodoList"
                     Grid.Row="1"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="TodoList_PreviewMouseLeftButtonDown"
                 MouseMove="TodoList_MouseMove"
                 Drop="TodoList_Drop"
                 ItemsSource="{Binding Todos}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{Binding MainItemPadding, RelativeSource={RelativeSource AncestorType=Window}}"
                                Tag="{Binding}"
                                MouseLeftButtonUp="TodoItem_MouseLeftButtonUp"
                                Cursor="Hand">
                            <StackPanel>
                                <StackPanel x:Name="MemoPinnedIndicator"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,2"
                                            Visibility="{Binding HasTopStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Path Data="M9.828.722a.5.5 0 0 1 .354.146l4.95 4.95a.5.5 0 0 1 0 .707c-.48.48-1.072.588-1.503.588-.177 0-.335-.018-.46-.039l-3.134 3.134a6 6 0 0 1 .16 1.013c.046.702-.032 1.687-.72 2.375a.5.5 0 0 1-.707 0l-2.829-2.828-3.182 3.182c-.195.195-1.219.902-1.414.707s.512-1.22.707-1.414l3.182-3.182-2.828-2.829a.5.5 0 0 1 0-.707c.688-.688 1.673-.767 2.375-.72a6 6 0 0 1 1.013.16l3.134-3.133a3 3 0 0 1-.04-.461c0-.43.108-1.022.589-1.503a.5.5 0 0 1 .353-.146"
                                          Fill="{DynamicResource TextMutedBrush}"
                                          Width="11"
                                          Height="11"
                                          Stretch="Uniform"
                                          Margin="0,2,6,0" />
                                    <TextBlock Text="{Binding StickyStatusText}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"
                                               FontFamily="Segoe UI Emoji, Segoe UI Symbol, Malgun Gothic" />
                                </StackPanel>                                <Grid MinHeight="{Binding RowHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                              Click="TodoChanged_Click"
                                              Visibility="{Binding IsMemo, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                              Margin="0,6,0,0"
                                              VerticalAlignment="Top" />

                                    <WrapPanel Grid.Column="1"
                                               VerticalAlignment="Top">
                                            <WrapPanel.Style>
                                                <Style TargetType="WrapPanel">
                                                    <Setter Property="Margin" Value="12,5,8,4" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMemo}" Value="True">
                                                            <Setter Property="Margin" Value="0,5,8,4" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </WrapPanel.Style>
                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TodoTextBrush}" />
                                                    <Setter Property="FontSize" Value="{Binding TodoFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Setter Property="TextDecorations" Value="{x:Null}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMemo}" Value="True">
                                                            <Setter Property="FontSize" Value="{Binding MemoFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource CompletedTextBrush}" />
                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ToggleButton IsChecked="{Binding IsSubTasksExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Content="▾"
                                                      Margin="3,-4,0,0"
                                                      Width="24"
                                                      Height="24"
                                                      FontSize="18">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource IconToggleStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SubTasks.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSubTasksExpanded}" Value="False">
                                                            <Setter Property="Content" Value="▸" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                    </WrapPanel>

                                    <Button Grid.Column="2"
                                            Tag="{Binding}"
                                            Click="ShowSubTodoInput_Click"
                                            Foreground="{DynamicResource AccentBrush}"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Top"
                                            Margin="0,4,0,0"
                                            Padding="0"
                                            MinWidth="{Binding AddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Width="{Binding AddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Height="{Binding AddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            FontSize="12"
                                            Visibility="{Binding IsMemo, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Style="{StaticResource ShellButtonStyle}">
                                        <Path Data="M 8 3 L 8 13 M 3 8 L 13 8"
                                              Stroke="{DynamicResource AccentBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Width="16"
                                              Height="16"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Button>
                                </Grid>

                                <WrapPanel Margin="28,0,0,4"
                                           >
                                    <WrapPanel.Style>
                                        <Style TargetType="WrapPanel">
                                            <Setter Property="Visibility" Value="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMemo}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </WrapPanel.Style>
                                    <Path Data="M9.828.722a.5.5 0 0 1 .354.146l4.95 4.95a.5.5 0 0 1 0 .707c-.48.48-1.072.588-1.503.588-.177 0-.335-.018-.46-.039l-3.134 3.134a6 6 0 0 1 .16 1.013c.046.702-.032 1.687-.72 2.375a.5.5 0 0 1-.707 0l-2.829-2.828-3.182 3.182c-.195.195-1.219.902-1.414.707s.512-1.22.707-1.414l3.182-3.182-2.828-2.829a.5.5 0 0 1 0-.707c.688-.688 1.673-.767 2.375-.72a6 6 0 0 1 1.013.16l3.134-3.133a3 3 0 0 1-.04-.461c0-.43.108-1.022.589-1.503a.5.5 0 0 1 .353-.146"
                                          Fill="{DynamicResource TextMutedBrush}"
                                          Width="11"
                                          Height="11"
                                          Stretch="Uniform"
                                          Margin="0,2,6,0"
                                          Visibility="Collapsed" />

                                    <TextBlock Text="{Binding DueDisplayText}"
                                              FontSize="12"
                                               Margin="0,0,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasDueDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDueToday}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text="{Binding NonDueDetailDisplay}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                </WrapPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="28,2,0,6">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsMemo}" Value="True" />
                                                        <Condition Binding="{Binding IsDeleted}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Content="스티키노트"
                                            Tag="{Binding}"
                                            Click="StickyMemo_Click"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            Padding="0"
                                            Margin="0,0,14,0"
                                            Style="{StaticResource ShellButtonStyle}" />                                    <Button Content="상단 고정"
                                            Tag="{Binding}"
                                            Click="PinMemo_Click"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            Padding="0"
                                            Margin="0,0,14,0"
                                            Style="{StaticResource ShellButtonStyle}" />
                                    <Button Content="휴지통"
                                            Tag="{Binding}"
                                            Click="TrashMemo_Click"
                                            Foreground="{DynamicResource DangerBrush}"
                                            Padding="0"
                                            Style="{StaticResource ShellButtonStyle}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="28,2,0,6">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsMemo}" Value="True" />
                                                        <Condition Binding="{Binding IsDeleted}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Content="蹂듦뎄"
                                            Tag="{Binding}"
                                            Click="RestoreMemo_Click"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Padding="0"
                                            Margin="0,0,14,0"
                                            Style="{StaticResource ShellButtonStyle}" />
                                    <Button Content="??젣"
                                            Tag="{Binding}"
                                            Click="DeleteMemoPermanently_Click"
                                            Foreground="{DynamicResource DangerBrush}"
                                            Padding="0"
                                            Style="{StaticResource ShellButtonStyle}" />
                                </StackPanel>
                                <Border Background="{StaticResource PanelBrush}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="12"
                                        Margin="28,6,0,8"
                                        Visibility="{Binding IsAddingSubTask, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding SubTaskDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 KeyDown="SubTodoBox_KeyDown"
                                                 LostKeyboardFocus="SubTodoBox_LostKeyboardFocus"
                                                 ToolTip="하위 할 일을 입력하고 Enter를 누르세요"
                                                 VerticalContentAlignment="Center" />

                                        <Button Grid.Column="1"
                                                Tag="{Binding}"
                                                Click="AddSubTodoInline_Click"
                                                FontWeight="SemiBold"
                                                Padding="0"
                                                MinWidth="34"
                                                Height="22"
                                                FontSize="12">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ShellButtonStyle}">
                                                    <Setter Property="Content" Value="추가" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SubTaskDraft}" Value="">
                                                            <Setter Property="Content" Value="취소" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SubTaskDraft.Length}" Value="0">
                                                            <Setter Property="Content" Value="취소" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SubTaskDraft}" Value="{x:Null}">
                                                            <Setter Property="Content" Value="취소" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding SubTasks}"
                                              Margin="28,0,0,0"
                                              AllowDrop="True"
                                              Visibility="{Binding IsSubTasksExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                              PreviewMouseLeftButtonDown="SubTodoList_PreviewMouseLeftButtonDown"
                                              MouseMove="SubTodoList_MouseMove"
                                              Drop="SubTodoList_Drop">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource SubItemMarginConverter}">
                                                        <Binding />
                                                        <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="ItemsSource" />
                                                        <Binding Path="SubItemMargin" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0">
                                                <StackPanel>
                                                    <Grid MinHeight="{Binding SubRowHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                                  Click="SubTodoChanged_Click"
                                                                  Margin="0,5,0,0"
                                                                  VerticalAlignment="Top" />

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Title}"
                                                                   FontSize="{Binding SubTodoFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Top"
                                                                   Margin="10,2,0,2"
                                                                   Tag="{Binding}"
                                                                   Cursor="Hand"
                                                                   MouseLeftButtonUp="SubTodoItem_MouseLeftButtonUp">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SubTodoTextBrush}" />
                                                                    <Setter Property="TextDecorations" Value="{x:Null}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMemo}" Value="True">
                                                            <Setter Property="FontSize" Value="{Binding MemoFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource CompletedTextBrush}" />
                                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>

                                                    <WrapPanel Margin="26,0,0,4"
                                                               Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding DueDisplayText}"
                                                                   FontSize="12"
                                                                   Visibility="{Binding HasDueDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDueToday}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                    <TextBlock Text="{Binding NonDueDetailDisplay}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasNonDueDetails, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <DockPanel Grid.Row="4" Margin="0,14,0,0" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="백업"
                        Click="Backup_Click"
                        Style="{StaticResource ShellButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="복원"
                        Click="Restore_Click"
                        Style="{StaticResource ShellButtonStyle}" />
            </StackPanel>

            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Text="以鍮꾨맖" />
        </DockPanel>

        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="5"
              Panel.ZIndex="100"
              Margin="-20"
              Background="{DynamicResource AppBackgroundBrush}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Canvas x:Name="LoadingSpriteCanvas"
                        Width="385"
                        Height="168"
                        HorizontalAlignment="Center" />

                <TextBlock x:Name="LoadingStatusText"
                           Text="濡쒕뵫以?"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />

                <TextBlock x:Name="LoadingVersionText"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
